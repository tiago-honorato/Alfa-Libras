# Normaliza os finais de linha para todos os arquivos de texto
* text=auto

# Força LF em arquivos de código e configs
*.cs text eol=lf
*.shader text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.txt text eol=lf

# Imagens e arquivos binários
*.png binary
*.jpg binary
*.jpeg binary
*.dll binary

# Ocultar arquivos de Shader das estatísticas de linguagem do GitHub
*.shader linguist-documentation=true
*.shadergraph linguist-documentation=true
*.hlsl linguist-documentation=true
*.cginc linguist-documentation=true

# HTML/CSS de alguma biblioteca ou UI do projeto
*.html linguist-documentation=true
*.css linguist-documentation=true
